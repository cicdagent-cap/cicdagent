# CI/CD Local Environment Template
# Copy this file: cp .env.example .notification.local.env
# Fill in values — DO NOT commit .notification.local.env

# Notification — copy your Teams/Slack webhook here
# Teams: Create incoming webhook in Teams → Apps → Connectors → Incoming Webhook
# Slack: Create webhook in Slack → Settings → App Management → Incoming Webhooks
TEAM_WEBHOOK_URL=https://your-webhook-url.com/path/to/webhook
CICD_CHAT_PROVIDER=teams

# Apple / Fastlane
FASTLANE_TEAM_ID=<apple-developer-team-id>
FASTLANE_ITC_TEAM_ID=<app-store-connect-team-id>
FASTLANE_BUNDLE_IDENTIFIER=com.example.app

# Fastlane Match (code signing)
MATCH_GIT_URL=git@github.com:your-org/certificates.git
MATCH_PASSWORD=<match-encryption-password>

# GitHub
GH_TOKEN=<github-personal-access-token>

# Firebase App Distribution
# App ID: Firebase console → Project Settings → General → "App ID"
FIREBASE_APP_ID=1:000000000000:ios:xxxxxxxxxxxxxxxx
# CLI token: run `firebase login:ci` locally to generate, store as GitHub secret
FIREBASE_CLI_TOKEN=<firebase-ci-token>
# Comma-separated tester group aliases defined in Firebase console
FIREBASE_GROUPS=testers
