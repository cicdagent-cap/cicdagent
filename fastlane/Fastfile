default_platform(:ios)

# Resolve an env var, falling back to `default` when the var is absent OR empty string.
def env_or(key, default)
  val = ENV[key].to_s.strip
  val.empty? ? default : val
end

platform :ios do

  desc "Build app (CI)"
  lane :build do
    project = env_or("CICD_PROJECT_FILE", "cicd.xcodeproj")
    scheme  = env_or("CICD_DEFAULT_SCHEME", "cicd")
    config  = env_or("CICD_DEFAULT_CONFIGURATION", "Debug")

    build_app(
      project: project,
      scheme: scheme,
      configuration: config,
      clean: true,
      skip_package_ipa: true
    )
  end

  desc "Run unit tests"
  lane :test do
    project = env_or("CICD_PROJECT_FILE", "cicd.xcodeproj")
    scheme  = env_or("CICD_DEFAULT_SCHEME", "cicd")

    dest = env_or(
      "CICD_TEST_DESTINATION",
      "platform=iOS Simulator,name=iPhone 16,OS=18.5"
    )

    run_tests(
      project: project,
      scheme: scheme,
      destination: dest,
      clean: true
    )
  end

  desc "Release build to TestFlight"
  lane :release do
    project = env_or("CICD_PROJECT_FILE", "cicd.xcodeproj")
    scheme  = env_or("CICD_DEFAULT_SCHEME", "cicd")
    notes   = env_or("RELEASE_NOTES", "")

    match(type: "appstore", readonly: true)

    build_app(
      project: project,
      scheme: scheme,
      configuration: "Release",
      clean: true
    )

    upload_to_testflight(
      changelog: notes,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build (ad-hoc) and distribute to Firebase App Distribution"
  lane :firebase_distribute do
    project = env_or("CICD_PROJECT_FILE", "cicd.xcodeproj")
    scheme  = env_or("CICD_DEFAULT_SCHEME", "cicd")
    config  = env_or("CICD_DEFAULT_CONFIGURATION", "Debug")
    app_id  = ENV["FIREBASE_APP_ID"].to_s.strip
    groups  = env_or("FIREBASE_GROUPS", "testers")
    notes   = env_or(
      "RELEASE_NOTES",
      "Build #{last_git_commit[:abbreviated_commit_hash]} on #{git_branch}"
    )

    UI.user_error!("FIREBASE_APP_ID must be set") if app_id.empty?

    match(type: "adhoc", readonly: true)

    build_app(
      project: project,
      scheme: scheme,
      configuration: config,
      clean: true,
      export_method: "ad-hoc"
    )

    firebase_app_distribution(
      app: app_id,
      groups: groups,
      release_notes: notes,
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"]
    )
  end

end