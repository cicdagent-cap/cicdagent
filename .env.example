# ============================================================================
# CI/CD Local Environment Template
# ============================================================================
# Copy this file: cp .env.example .notification.local.env
# Fill in YOUR VALUES — DO NOT commit .notification.local.env to git
# This file is for LOCAL DEVELOPMENT ONLY
# ============================================================================

# ============================================================================
# CORE CI/CD SETTINGS (also set as GitHub Repository Variables)
# ============================================================================
CICD_PROJECT_FILE=cicd.xcodeproj
CICD_DEFAULT_SCHEME=cicd
CICD_DEFAULT_CONFIGURATION=Debug
CICD_TEST_DESTINATION=platform=iOS Simulator,name=iPhone 15,OS=latest

# ============================================================================
# XCODEBUILD TIMEOUT SETTINGS (prevents "showBuildSettings" timeout)
# ============================================================================
# Default: 3 seconds — usually causes timeout errors
# Recommended: 180 seconds for CI/CD environments
FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT=180
FASTLANE_XCODEBUILD_SETTINGS_RETRIES=10
XCBUILD_TIMEOUT=300

# ============================================================================
# APPLE DEVELOPER ACCOUNT & FASTLANE
# ============================================================================
# Team ID: Apple Developer Portal → Account → Memberships
FASTLANE_TEAM_ID=<apple-developer-team-id>
# Also called "Provider ID" — App Store Connect → Users and Access → Account Holder
FASTLANE_ITC_TEAM_ID=<app-store-connect-team-id>
# Bundle identifier: Xcode → Build Settings → Bundle Identifier
FASTLANE_BUNDLE_IDENTIFIER=com.example.app

# ============================================================================
# CODE SIGNING: FASTLANE MATCH
# ============================================================================
# Git repository where code signing certificates are stored (encrypted)
# Format: git@github.com:your-org/certificates.git or https://github.com/your-org/certificates.git
MATCH_GIT_URL=git@github.com:your-org/certificates.git
# Password to decrypt match repository
MATCH_PASSWORD=<match-encryption-password>
# Basic auth token if match repo requires authentication
MATCH_GIT_BASIC_AUTHORIZATION=<base64-user-colon-token>
# Username for match (usually your Apple ID email)
MATCH_USERNAME=<your-apple-id-email>
# Apple ID password (consider using app-specific password for security)
MATCH_PASSWORD_KEYCHAIN=<apple-id-password>

# ============================================================================
# FIREBASE APP DISTRIBUTION (for beta/internal testing)
# ============================================================================
# App ID: Firebase Console → Project Settings → General → "App ID"
# Format: 1:000000000000:ios:xxxxxxxxxxxxxxxx
FIREBASE_APP_ID=<firebase-app-id>
# CLI token: Generate locally with: firebase login:ci
# This is a secret — store in GitHub Secrets, NOT in .notification.local.env
# FIREBASE_TOKEN is loaded from GitHub secrets only
FIREBASE_GROUPS=testers
# Optional: Comma-separated list of additional tester group aliases
RELEASE_NOTES=Build from CI/CD pipeline

# ============================================================================
# NOTIFICATIONS: TEAMS & SLACK WEBHOOKS
# ============================================================================
# Microsoft Teams: Setup → Connectors → Incoming Webhook → Get webhook URL
# Slack: Apps → Incoming Webhooks → Create New Webhook → Copy URL
# This is a secret — store in GitHub Secrets, NOT in .notification.local.env
# TEAMS_WEBHOOK_URL is loaded from GitHub secrets only
TEAMS_WEBHOOK_URL=<teams-webhook-url>

# ============================================================================
# GITHUB & GIT CONFIGURATION
# ============================================================================
# GitHub Personal Access Token (for creating PRs and pushing commits)
# Settings → Developer settings → Personal access tokens → Generate new token
# Required scopes: repo, workflow
GH_TOKEN=<github-personal-access-token>

# ============================================================================
# IPA BUILD SETTINGS
# ============================================================================
# Options: ad-hoc, app-store, development, enterprise
IPA_EXPORT_METHOD=ad-hoc

# ============================================================================
# OPTIONAL: ANALYTICS & LOGGING
# ============================================================================
# Fastlane analytics opt-out
FASTLANE_OPT_OUT_USAGE=YES
# Verbose logging (for debugging)
# FASTLANE_VERBOSE=true
